{
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "open": "bun ./src/index.ts",
    "build": "bun build:windows",
    "build:windows": "bun build --minify --compile ./src/index.ts --outfile=dist/savefile-analyzer.exe --target=bun-windows-x64",
    "build:linux": "bun build --minify --compile ./src/index.ts --outfile=dist/savefile-analyzer-linux-x64 --target=bun-linux-x64",
    "build:macos": "bun build --minify --compile ./src/index.ts --outfile=dist/savefile-analyzer-darwin-x64 --target=bun-darwin-x64"
  },
  "dependencies": {
    "savefile.js": "0.0.5"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  }
}
